def mat(key):
    k = ""
    for i in key:
        if i not in k:
            k += i
    a = "ABCDEFGHIKLMNOPQRSTUVWXYZ"
    for i in a:
        if i not in k:
            k += i
    m = [k[i:i+5] for i in range(0, 25, 5)]
    return m

def pos(m, x):
    for i in range(5):
        for j in range(5):
            if m[i][j] == x:
                return i, j

def prep(p):
    p = p.upper().replace(" ", "").replace("J", "I")
    r = ""
    i = 0
    while i < len(p):
        a = p[i]
        b = p[i+1] if i+1 < len(p) else "X"
        if a == b:
            r += a + "X"
            i += 1
        else:
            r += a + b
            i += 2
    if len(r) % 2 != 0:
        r += "X"
    return r

def playfair(p, m):
    c = ""
    for i in range(0, len(p), 2):
        r1, c1 = pos(m, p[i])
        r2, c2 = pos(m, p[i+1])

        if r1 == r2:
            c += m[r1][(c1+1)%5] + m[r2][(c2+1)%5]
        elif c1 == c2:
            c += m[(r1+1)%5][c1] + m[(r2+1)%5][c2]
        else:
            c += m[r1][c2] + m[r2][c1]
    return c
p = input("enter plain text: ")

key = "MONARCHY"
m = mat(key)
p = prep(p)
c = playfair(p, m)

print(p)
print(c)


