import numpy as np

def c2n(x):
    return ord(x) - 65

def n2c(x):
    return chr(x + 65)

def inv(k):
    d = int(round(np.linalg.det(k)))
    d = d % 26

    for i in range(26):
        if (d * i) % 26 == 1:
            di = i
            break

    a, b = k[0][0], k[0][1]
    c, e = k[1][0], k[1][1]

    ki = np.array([[e, -b],
                   [-c, a]])

    ki = (di * ki) % 26
    return ki

def hill_dec(c, k):
    ki = inv(k)
    p = ""

    for i in range(0, len(c), 2):
        v = np.array([c2n(c[i]), c2n(c[i+1])])
        r = np.dot(ki, v) % 26
        p += n2c(r[0]) + n2c(r[1])

    return p

k = np.array([[3, 3],
              [2, 5]])

c = "HIOZHN"

p = hill_dec(c, k)

print(c)
print(p)


