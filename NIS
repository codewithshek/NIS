import numpy as np

def c2n(x):
    return ord(x) - 65

def n2c(x):
    return chr(x + 65)

def hill(p, k):
    p = p.upper().replace(" ", "")
    if len(p) % 2 != 0:
        p += "X"

    c = ""

    for i in range(0, len(p), 2):
        v = np.array([c2n(p[i]), c2n(p[i+1])])
        r = np.dot(k, v) % 26
        c += n2c(r[0]) + n2c(r[1])

    return c

k = np.array([[3, 3],
              [2, 5]])

p = "HELLO"

c = hill(p, k)

print(p)
print(c)


