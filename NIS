def mat(key):
    k = ""
    for i in key:
        if i not in k:
            k += i
    a = "ABCDEFGHIKLMNOPQRSTUVWXYZ"
    for i in a:
        if i not in k:
            k += i
    m = [k[i:i+5] for i in range(0, 25, 5)]
    return m

def pos(m, x):
    for i in range(5):
        for j in range(5):
            if m[i][j] == x:
                return i, j

def playfair_dec(c, m):
    p = ""
    for i in range(0, len(c), 2):
        r1, c1 = pos(m, c[i])
        r2, c2 = pos(m, c[i+1])

        if r1 == r2:
            p += m[r1][(c1-1)%5] + m[r2][(c2-1)%5]
        elif c1 == c2:
            p += m[(r1-1)%5][c1] + m[(r2-1)%5][c2]
        else:
            p += m[r1][c2] + m[r2][c1]
    return p

key = "MONARCHY"
c = "LIEMAKQD"

m = mat(key)
p = playfair_dec(c, m)

print(c)
print(p)


